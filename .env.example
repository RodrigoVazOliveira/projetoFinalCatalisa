# Variáveis de Ambiente para Docker Compose
# Copie este arquivo para .env e preencha com seus valores

# Email (Gmail)
EMAIL=seu-email@gmail.com
SENHA=sua-senha-app-gmail

# JWT
SECRET=sua-secret-jwt-super-secreto-e-longo-no-minimo-32-caracteres
TIMEOUT_LIMIT=3600000

# Nota: As variáveis de banco de dados (URL, USER_BANCO_DADOS, PASSWORD_BANCO)
# estão configuradas diretamente no docker-compose.yml por serem internas à rede

